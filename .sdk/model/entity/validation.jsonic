# Entity: validation

main: kit: entity: validation: {

  alias: field: {}

  fields: [
    {
      name: "data"
      req: false
      type: "`$OBJECT`"
    }
    {
      name: "message"
      req: false
      type: "`$STRING`"
    }
    {
      name: "success"
      req: false
      type: "`$BOOLEAN`"
    }
  ]

  name: "validation"
  op: {
    load: {
      name: "load"
      points: [
        {
          args: {
            query: [
              {
                example: "sample text"
                kind: "query"
                name: "text"
                orig: "text"
                reqd: true
                type: "`$STRING`"
              }
            ]
          }
          method: "GET"
          orig: "/api/search/ringtone"
          parts: [
            "api"
            "search"
            "ringtone"
          ]
          select: {
            exist: [
              "text"
            ]
          }
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }



}
